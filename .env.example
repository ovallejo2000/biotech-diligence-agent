# -------------------------------------------------------
# Biotech Diligence Agent — Provider Configuration
# Copy this file to .env and fill in ONE provider below.
# The system auto-detects which key is set (priority order).
# -------------------------------------------------------

# OPTION 1: Anthropic Claude (paid — best quality)
# ANTHROPIC_API_KEY=sk-ant-...

# OPTION 2: Groq (FREE — no credit card, great quality)
# Sign up at https://console.groq.com
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile   # optional, this is the default

# OPTION 3: Google Gemini (FREE — Google account only)
# Get key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-1.5-flash        # optional, this is the default

# OPTION 4: Ollama (FREE — runs locally, no account needed)
# Install: brew install ollama
# Start:   ollama serve
# Pull:    ollama pull llama3.1
# OLLAMA_MODEL=llama3.1                # set this to enable Ollama
# OLLAMA_HOST=http://localhost:11434   # optional, this is the default
